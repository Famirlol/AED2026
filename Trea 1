#include <iostream>
using namespace std;

template<class T, int n = 10>
struct cola {
    int num_elem;
    T* arr;
    T* head;
    T* tail;

    cola();
    ~cola();
    bool vacio();
    bool lleno();
    bool push(T val);
    bool pop(T& val);
};

template<class T, int n>
cola<T, n>::cola() {
    num_elem = n;
    arr = new T[num_elem];
    head = NULL;
    tail = NULL;
}

template<class T, int n>
bool cola<T, n>::vacio()
{
    return head == NULL;
}

template<class T, int n>
bool cola<T, n>::lleno()
{
    if (vacio())
        return false;

    if (tail + 1 == head)
        return true;

    if (tail == arr + num_elem - 1 && head == arr)
        return true;

    return false;
}

template<class T, int n>
bool cola<T, n>::push(T val)
{
    if (lleno())
        return false;

    if (vacio()) {
        head = arr;
        tail = arr;
    }
    else {
        if (tail == arr + num_elem - 1)
            tail = arr;
        else
            tail++;
    }

    *tail = val;
    return true;
}

template<class T, int n>
bool cola<T, n>::pop(T& val)
{
    if (vacio())
        return false;

    val = *head;

    if (head == tail) {
        head = NULL;
        tail = NULL;
        return true;
    }

    if (head == arr + num_elem - 1)
        head = arr;
    else
        head++;

    return true;
}

template<class T, int n>
cola<T, n>::~cola()
{
    delete[]arr;
}

int main() {
    cola<int, 10> c;

    int n, x;

    cout << "Cuantos elementos desea ingresar: ";
    cin >> n;

    if (n > 10) {
        cout << "Excede la capacidad de la cola\n";
        return 0;
    }

    for (int i = 0; i < n; i++) {
        cout << "Ingrese valor: ";
        cin >> x;

        if (!c.push(x)) {
            cout << "Cola llena\n";
            break;
        }
    }

    cout << "\nElementos en orden FIFO:\n";

    while (!c.vacio()) {
        if (c.pop(x)) {
            cout << x << " ";
        }
    }

    cout << endl;

    return 0;
}
