#include <iostream>
using namespace std;

template<class T, int n = 10>
struct cola {
    int num_e;
    T* arr;
    T* head;
    T* cola;

    cola();
    ~cola();
    bool vacio();
    bool lleno();
    bool push(T val);
    bool pop(T& val);
};

template<class T, int n>
cola<T, n>::cola() {
    num_e = n;
    arr = new T[num_e];
    head = NULL;
    cola = NULL;
}

template<class T, int n>
bool cola<T, n>::vacio()
{
    return head == NULL;
}

template<class T, int n>
bool cola<T, n>::lleno()
{
    if (vacio())
        return false;

    if (cola + 1 == head)
        return true;

    if (cola == arr + num_e - 1 && head == arr)
        return true;

    return false;
}

template<class T, int n>
bool cola<T, n>::push(T val)
{
    if (lleno())
        return false;

    if (vacio()) {
        head = arr;
        cola = arr;
    }
    else {
        if (cola == arr + num_e - 1)
            cola = arr;
        else
            cola++;
    }

    *cola = val;
    return true;
}

template<class T, int n>
bool cola<T, n>::pop(T& val)
{
    if (vacio())
        return false;

    val = *head;

    if (head == cola) {
        head = NULL;
        cola = NULL;
        return true;
    }

    if (head == arr + num_e - 1)
        head = arr;
    else
        head++;

    return true;
}

template<class T, int n>
cola<T, n>::~cola()
{
    delete[]arr;
}

int main() {
    cola<int, 10> c;

    int n, x;

    cout << "Cantidad de elementos";
    cin >> n;

    if (n > 10) {
        cout << "La cantidad es demasiada\n";
        return 0;
    }

    for (int i = 0; i < n; i++) {
        cout << "Ingrese valor: ";
        cin >> x;

        if (!c.push(x)) {
            cout << "colala llena\n";
            break;
        }
    }

    cout << "\nElementos en orden:\n";

    while (!c.vacio()) {
        if (c.pop(x)) {
            cout << x << " ";
        }
    }

    cout << endl;

    return 0;
}
